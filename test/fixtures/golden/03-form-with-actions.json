{
  "$prefab": {
    "version": "0.2"
  },
  "view": {
    "cssClass": "pf-app-root",
    "type": "Div",
    "children": [
      {
        "cssClass": "gap-4",
        "type": "Column",
        "children": [
          {
            "content": "Contact Form",
            "type": "Heading",
            "level": 2
          },
          {
            "name": "email",
            "type": "Input",
            "inputType": "text",
            "placeholder": "you@example.com",
            "disabled": false,
            "readOnly": false,
            "required": false
          },
          {
            "name": "message",
            "type": "Textarea",
            "placeholder": "Your message...",
            "disabled": false,
            "required": false
          },
          {
            "type": "Button",
            "label": "Submit",
            "variant": "default",
            "size": "default",
            "disabled": false,
            "onClick": {
              "action": "callHandler",
              "handler": "submit_form"
            }
          }
        ]
      }
    ]
  },
  "state": {
    "email": "",
    "message": ""
  }
}