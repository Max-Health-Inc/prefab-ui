{
  "$prefab": {
    "version": "0.2"
  },
  "view": {
    "cssClass": "pf-app-root",
    "type": "Div",
    "children": [
      {
        "cssClass": "gap-4",
        "type": "Column",
        "children": [
          {
            "type": "Card",
            "children": [
              {
                "type": "CardContent",
                "children": [
                  {
                    "content": "Dashboard content here.",
                    "type": "Text"
                  }
                ]
              }
            ]
          },
          {
            "type": "Button",
            "label": "Toggle dark mode",
            "variant": "default",
            "size": "default",
            "disabled": false,
            "onClick": {
              "action": "toggleState",
              "key": "darkMode"
            }
          }
        ]
      }
    ]
  },
  "defs": {
    "greeting": {
      "cssClass": "gap-2",
      "type": "Column",
      "children": [
        {
          "content": "Welcome back!",
          "type": "Heading",
          "level": 1
        },
        {
          "content": "You have new notifications.",
          "type": "Muted"
        }
      ]
    }
  },
  "state": {
    "darkMode": false,
    "user": {
      "name": "Alice"
    }
  }
}